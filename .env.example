# =============================================================================
# Ops Command Center — environment template
# Copy to .env.local (web) and apps/realtime/.env (realtime) before pnpm dev.
# =============================================================================

# ---------- shared / docker compose ----------

# Postgres (started by `docker compose up -d postgres`)
POSTGRES_USER=ops
POSTGRES_PASSWORD=ops
POSTGRES_DB=ops
POSTGRES_PORT=5432

# Connection string used by apps/web's Drizzle client + db:migrate / db:seed
DATABASE_URL=postgres://ops:ops@localhost:5432/ops

# ---------- apps/web ----------

# Auth.js (NextAuth v5) — generate with: openssl rand -base64 32
AUTH_SECRET=

# Public origin of the web app — used by Auth.js for callbacks
AUTH_URL=http://localhost:3000

# Google OIDC — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Single-operator escape hatch: set to 1 to re-enable the dev credentials
# bypass on a production build (lets you sign in as any role without OIDC).
# Only safe when access to the URL is restricted (VPN, Tailscale, local
# network). A loud banner shows in the UI whenever this is on.
ALLOW_DEV_BYPASS=

# WS service (browser connects directly; same origin in prod via reverse proxy)
NEXT_PUBLIC_REALTIME_URL=ws://localhost:4001

# Shared secret used to sign the short-lived WS upgrade JWT.
# Web mints, realtime verifies. Same value in both apps.
REALTIME_JWT_SECRET=

# Shared secret for apps/realtime → apps/web internal sync calls.
# Both apps need the same value. Generate with: openssl rand -base64 32
SYNC_SECRET=

# Outbound webhook delivery signing. apps/realtime signs every delivery's
# body with HMAC-SHA256 and sends `x-ops-signature: sha256=<hex>`. Receivers
# verify with the same secret. Empty = unsigned deliveries.
WEBHOOK_SECRET=

# Eval execution — when set, apps/realtime's eval-tick calls the real
# model APIs and scores cases against expected_pattern. Leave both
# empty for the deterministic mock provider (no API spend).
EVAL_ANTHROPIC_KEY=
EVAL_OPENAI_KEY=

# URL the realtime worker uses to reach apps/web for sync calls.
# Defaults to http://127.0.0.1:3000 when unset. In compose this should be the
# service DNS name (e.g. http://web:3000).
SYNC_WEB_URL=http://127.0.0.1:3000

# ---------- per-connector envs (resolved by env:NAME refs in connection rows) ----------

# Proxmox: PVEAPIToken USER@REALM!TOKENID's secret half. Token ID + host live
# in the connection row in the database; this is just the secret half.
PROXMOX_TOKEN=

# Anthropic API key — required only if you want the connector test to call
# /v1/models. Not needed for agents that push via /api/ingest with their own
# bearer tokens.
ANTHROPIC_API_KEY=

# GitHub personal access token (read-only is fine for the test endpoint)
GITHUB_TOKEN=

# n8n API key — referenced from the n8n connection's `api_key` field as
# env:N8N_API_KEY. Only needed if you wire up an n8n connector.
N8N_API_KEY=

# n8n inbound webhook signing secret — referenced from the n8n connection's
# `webhook_secret` field as env:N8N_WEBHOOK_SECRET.
N8N_WEBHOOK_SECRET=

# ---------- apps/realtime ----------

# Bind address + port for the standalone WS server
REALTIME_HOST=127.0.0.1
REALTIME_PORT=4001
